# Auto detect text files and normalize line endings to LF on checkout.
* text=auto

# Source code
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Ensure batch files retain CRLF for Windows users
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
